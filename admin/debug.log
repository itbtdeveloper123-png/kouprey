    [custom_fields_data_edit] => {"custom_field_1766717393718_uc68a6glk":{"name":{"en":"Ingredients:","km":"គ្រឿងផ្សំសំខាន់ៗ៖"},"value":{"en":"Edible Glucose, Non-Dairy Creamer (Glucose Syrup, Refined Palm Oil,\nSodium Caseinate, Dipotassium Phosphate, Sodium Carboxymethyl Cellulose, Mono-and Diglycerides, Sodium Stearoyl Lactylate, Lecithin, Silicon Dioxide, Food Flavoring), White Sugar, Instant Black Tea Powder, Lactose, Food Additives (Acesulfame Potassium, Silicon Dioxide), Flavoring","km":"Edible Glucose: ស្ករគ្លុយកូស (ស្ករម្សៅដែលអាចបរិភោគបាន),Non-Dairy Creamer: ម្សៅគ្រីមមឺរ (ម្សៅទឹកដោះគោរុក្ខជាតិ) ដែលផ្សំឡើងពី៖(Glucose Syrup: សុីរ៉ូស្ករគ្លុយកូស,Refined Palm Oil: ប្រេងដូងចម្រាញ់,Sodium Caseinate: សូដ្យូម កាសេអ៊ីណាត (ជាតិប្រូតេអ៊ីនស្រង់ចេញពីទឹកដោះគោ ដើម្បីឱ្យមានជាតិខ្ទិះ),White Sugar: ស្ករស,Instant Black Tea Powder: ម្សៅតែខ្មៅឆុងភ្លាមៗ,Lactose: ឡាក់តូស (ស្ករដែលមាននៅក្នុងទឹកដោះគោ),សារធាតុបន្ថែមដើម្បីរក្សាគុណភាព និងរសជាតិ (Food Additives),Acesulfame Potassium: សារធាតុផ្អែមជំនួសស្ករ (ផ្អែមខ្លាំងតែអត់កាឡូរី)។Silicon Dioxide: សារធាតុប្រឆាំងការកកដុំ (ជួយឱ្យម្សៅហុយល្អ មិនដុំៗ)។,Food Flavoring / Flavoring: ភ្នាក់ងារបង្កើនក្លិន និងរសជាតិអាហារ។"},"type":"text"},"custom_field_1766717688750_es6y5z95b":{"name":{"en":"Storage conditions:","km":"លក្ខខណ្ឌផ្ទុក៖"},"value":{"en":"stored in cool, dry, light-proof\nplace, after opening, please use it in time or keep it sealed.","km":"សូមរក្សាទុកក្នុងកន្លែងត្រជាក់ ស្ងួត និងមិនត្រូវពន្លឺថ្ងៃ។ ក្រោយពេលបើកប្រើរួចរាល់ សូមបិទមាត់ថង់/ដបឱ្យជិតវិញ។"},"type":"text"},"custom_field_1766717804836_suqgfselp":{"name":{"en":"Direction:","km":"របៀបឆុង៖"},"value":{"en":"Into a shaker, add in order: 30g of fructose, 20g of non-dairy creamer, 10g of this product (black tea base), and 180mL of brewed black tea. Then, add ice to the brim. Shake vigorously 20 times to serve.","km":"១. ដាក់គ្រឿងផ្សំចូលក្នុងកែវក្រឡុក (Shaker) តាមលំដាប់លំដោយ៖\n\nស្ករទឹក (Fructose): ៣០ ក្រាម\n\nម្សៅទឹកដោះគោ (Non-dairy creamer): ២០ ក្រាម\n\nម្សៅតែខ្មៅ (ផលិតផលនេះ): ១០ ក្រាម\n\nទឹកតែខ្មៅ (ដែលឆុងរួច): ១៨០ មីលីលីត្រ\n\n២. បន្ថែមទឹកកក៖ ដាក់ទឹកកកចូលឱ្យពេញមាត់កែវក្រឡុក។\n\n៣. ក្រឡុក៖ ក្រឡុកឱ្យខ្លាំងៗចំនួន ២០ ដង រួចចាក់ដាក់កែវជាការស្រេច។"},"type":"text"},"custom_field_1766717923668_gqulrnh0l":{"name":{"en":"Shelf life:","km":"អាយុកាល"},"value":{"en":"12 months","km":"១២​ ខែ"},"type":"text"},"custom_field_1766717959188_28lnk573s":{"name":{"en":"Allergen information:","km":"ព័ត៌មានអំពីសារធាតុបង្កអាឡែហ្ស៊ី៖"},"value":{"en":"This production line simultaneously produces products containing dairy products, grains, peanuts, soybeans, and nuts","km":"ខ្សែសង្វាក់ផលិតកម្មនេះ ក៏ផលិតនូវផលិតផលផ្សេងទៀតដែលមានផ្ទុកនូវ គ្រឿងផ្សំពីទឹកដោះគោ, គ្រាប់ធញ្ញជាតិ, សណ្តែកដី, សណ្តែកសៀង និងគ្រាប់រុក្ខជាតិផ្សេងៗ ក្នុងពេលតែមួយផងដែរ។\nឃ្លានេះគឺជាការព្រមានសម្រាប់អ្នកដែលមាន ប្រតិកម្ម (អាឡែហ្ស៊ី) ជាមួយអាហារខាងលើ។ ទោះបីជាផលិតផលដែលអ្នកទិញមិនមែនជាប្រភេទសណ្តែក ឬទឹកដោះគោក៏ដោយ ប៉ុន្តែវាត្រូវបានផលិតចេញពីម៉ាស៊ីនជាមួយគ្នា ដែលអាចធ្វើឱ្យមានការ \"ឆ្លងមេរោគអាឡែហ្ស៊ី\" បន្តិចបន្តួចពីផលិតផលមួយទៅផលិតផលមួយទៀតបាន។"},"type":"text"},"custom_field_1766718269340_wpi8a9sgr":{"name":{"en":"Nutrition information:","km":"ព័ត៌មានអាហារូបត្ថម្ភ៖"},"value":[{"label":{"en":"energy","km":"ថាមពល"},"value":[{"en":"1540KJ","km":"1540KJ"},{"en":"18%","km":"18%"}]},{"label":{"en":"protein","km":"ប្រូតេអ៊ីន"},"value":[{"en":"0g","km":"0g"},{"en":"0%","km":"0%"}]},{"label":{"en":"fat","km":"ខ្លាញ់"},"value":[{"en":"4.5g","km":"4.5g"},{"en":"8%","km":"8%"}]},{"label":{"en":"carbohydrate","km":"កាបូអ៊ីដ្រាត"},"value":[{"en":"80.8g","km":"80.8g"},{"en":"27%","km":"27%"}]},{"label":{"en":"sodium","km":"សូដ្យូម"},"value":[{"en":"30mg","km":"30mg"},{"en":"2%","km":"2%"}]}],"type":"table"},"custom_field_1766718133876_mhc1t3bun":{"name":{"en":"Origin:","km":"ប្រភព៖"},"value":{"en":"China","km":"ប្រទេសចិន"},"type":"text"}}
