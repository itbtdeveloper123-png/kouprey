    [custom_fields_data_edit] => {"custom_field_1766725941298_1rtghad1l":{"name":{"en":"Ingredients:","km":"គ្រឿងផ្សំសំខាន់ៗ៖"},"value":{"en":"vegetable fat powder (glucose\nsyn, hydrogenated vegetable oil, milk powder, emulsifier (sodium caseinate, mono-glyceride fatty acid esters, sodium stearoyl lactate), stabilizer (dipotassium hydrogen phosphate), coloring agent (cochineal orange), anti caking agent (silicon dioxide)), edible flavoring.","km":"ម្សៅខ្លាញ់រុក្ខជាតិ (Vegetable Fat Powder),ស៊ីរ៉ូកុយកូស (Glucose Syrup): ជាតិស្ករដែលបានមកពីម្សៅឆ្មារ ជួយឱ្យមានរសជាតិផ្អែមតិចៗ និងរក្សារូបរាងម្សៅ។,ប្រេងរុក្ខជាតិដែលបានចម្រាញ់ (Hydrogenated Vegetable Oil): ជាប្រភេទខ្លាញ់ដែលគេកែច្នៃឱ្យទៅជាសភាពរឹង ដើម្បីជួយឱ្យអាហារទុកបានយូរ និងមានជាតិរអិលមាត់។,ម្សៅទឹកដោះគោ (Milk Powder): បន្ថែមរសជាតិទឹកដោះគោ។,សារធាតុរក្សាលំនឹង/សារធាតុបញ្ចុះ (Emulsifier),Sodium Caseinate: ប្រូតេអ៊ីនទឹកដោះគោ។,Mono-glyceride fatty acid esters: ខ្លាញ់ជួយឱ្យសាច់អាហារម៉ដ្តរលោង។,Sodium stearoyl lactate: ជួយឱ្យសាច់នំ ឬម្សៅមានភាពយឺត និងទន់។,សារធាតុទប់លំនឹង (Stabilizer - Dipotassium hydrogen phosphate): ជួយកុំឱ្យទឹកដោះគោរងកក ឬបែកស្រទាប់។,សារធាតុពណ៌ (Coloring agent - Cochineal orange): ល័ក្ខពណ៌ទឹកក្រូច។,សារធាតុប្រឆាំងការកកដុំ (Anti-caking agent - Silicon dioxide): ជួយឱ្យម្សៅហូរល្អ មិនស្អិតជាប់គ្នាជាដុំៗ។,គ្រឿងក្រអូប (Edible Flavoring): ក្លិនឈ្ងុយសម្រាប់បរិភោគ។"},"type":"text"},"custom_field_1766726064393_wr47xt4st":{"name":{"en":"Directions:","km":"របៀបឆុង៖"},"value":{"en":"Add this product to coffee, tea and other drinks for flavoring, with the addition amount of 5%-10%.","km":"សូមបន្ថែមផលិតផលនេះទៅក្នុងកាហ្វេ តែ ឬភេសជ្ជៈផ្សេងៗ ដើម្បីបង្កើនរសជាតិ ក្នុងកម្រិតពី ៥% ទៅ ១០%។"},"type":"text"},"custom_field_1766726185538_p7nh7iz4z":{"name":{"en":"Storage conditions:","km":"លក្ខខណ្ឌផ្ទុក៖"},"value":{"en":"stored in a cool and dry\nplace, please use it in time or keep it in a sealed place after opening.","km":"សូមរក្សាទុកនៅកន្លែងត្រជាក់ និងស្ងួត។ ក្រោយពេលបើកប្រើ សូមប្រើឱ្យអស់ក្នុងរយៈពេលខ្លី ឬបិទមាត់ថង់/ប្រអប់ឱ្យជិតល្អឡើងវិញ។"},"type":"text"},"custom_field_1766726185953_vbbrqzq2g":{"name":{"en":"Shelf life:","km":"អាយុកាល៖"},"value":{"en":"18 months","km":"១៨ ខែ"},"type":"text"},"custom_field_1766726186306_m1yixvg2g":{"name":{"en":"Allergen information:","km":"ព័ត៌មានអំពីសារធាតុបង្កអាឡែហ្ស៊ី៖"},"value":{"en":"This production line simultaneously produces products containing dairy products, grains, peanuts, soybeans, and nuts","km":"ខ្សែសង្វាក់ផលិតកម្មនេះ ក៏ផលិតនូវផលិតផលផ្សេងទៀតដែលមានផ្ទុកនូវ គ្រឿងផ្សំពីទឹកដោះគោ, គ្រាប់ធញ្ញជាតិ, សណ្តែកដី, សណ្តែកសៀង និងគ្រាប់រុក្ខជាតិផ្សេងៗ ក្នុងពេលតែមួយផងដែរ។\nឃ្លានេះគឺជាការព្រមានសម្រាប់អ្នកដែលមាន ប្រតិកម្ម (អាឡែហ្ស៊ី) ជាមួយអាហារខាងលើ។ ទោះបីជាផលិតផលដែលអ្នកទិញមិនមែនជាប្រភេទសណ្តែក ឬទឹកដោះគោក៏ដោយ ប៉ុន្តែវាត្រូវបានផលិតចេញពីម៉ាស៊ីនជាមួយគ្នា ដែលអាចធ្វើឱ្យមានការ \"ឆ្លងមេរោគអាឡែហ្ស៊ី\" បន្តិចបន្តួចពីផលិតផលមួយទៅផលិតផលមួយទៀតបាន។"},"type":"text"},"custom_field_1766726359810_30mu286f1":{"name":{"en":"Nutrition information:","km":"ព័ត៌មានអាហារូបត្ថម្ភ៖"},"value":[{"label":{"en":"Energy","km":"ថាមពល"},"value":[{"en":"2233KJ","km":"2233KJ"},{"en":"27%","km":"27%"}]},{"label":{"en":"Protein","km":"ប្រូតេអ៊ីន"},"value":[{"en":"3.4g","km":"3.4g"},{"en":"6%","km":"6%"}]},{"label":{"en":"Trans fats (acid)","km":"ខ្លាញ់ trans (អាស៊ីត)"},"value":[{"en":"6.9g","km":"6.9g"},{"en":"0%","km":"0%"}]},{"label":{"en":"Carbohydrate","km":"កាបូអ៊ីដ្រាត"},"value":[{"en":"57.0g","km":"57.0g"},{"en":"19%","km":"19%"}]},{"label":{"en":"Sodium","km":"សូដ្យូម"},"value":[{"en":"240mg","km":"240mg"},{"en":"12%","km":"12%"}]}],"type":"table"}}
