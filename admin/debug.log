    [custom_fields_data_edit] => {"custom_field_1766720146777_bto1r07gr":{"name":{"en":"Ingredients:","km":"គ្រឿងផ្សំសំខាន់ៗ៖"},"value":{"en":"Milk powder (glucose syrup, hydrogenated vegetable oil, milk powder, mono-and diglyceride fatty acid esters, sodium stearoyl lactylate, dipotassium phosphate, silicon dioxide, food flavouring), dextrose, mono- and diglyceride fatty acid esters, sodium caseinate, dipotassium phosphate, dipotassium phosphate, salt, sodium carboxymethylcellulose.\nDirections: Add 500 g of evergreen cream, 1000 g of milk, and 500 g of cap powder to the blender container at one time. Add 500g of Evergreen Cream, 1000g of fresh milk and 500g of milk cap powder to the blender container, stir manually with a spatula, press down the blender and turn it to medium speed for 2-8 minutes. The hardness can be increased with the extension of the mixing time.","km":"ម្សៅទឹកដោះគោ៖ (រួមមាន សុីរ៉ូកុយកូស, ប្រេងបន្លែ, ជាតិខ្លាញ់ដែលចម្រាញ់ចេញពីអាស៊ីតខ្លាញ់, សារធាតុរក្សាតុល្យភាពរសជាតិ, និងក្លិនក្រអូបសម្រាប់អាហារ)។ ស្ករដេស្ត្រូស (Dextrose): ប្រភេទស្ករម្សៅម្យ៉ាង។ សូដ្យូមកាសេអ៊ីណាត (Sodium Caseinate): ប្រូតេអ៊ីនដែលចម្រាញ់ពីទឹកដោះគោ។ អំបិល និងសារធាតុបង្កើនភាពខាប់ (Sodium Carboxymethylcellulose)។"},"type":"text"},"custom_field_1766720321185_rcs06s66r":{"name":{"en":"How to cook:","km":"របៀបឆុង៖"},"value":{"en":"Add 500 g of evergreen cream, 1000 g of milk, and 500 g of cap powder to the blender container at one time. Add 500g of Evergreen Cream, 1000g of fresh milk and 500g of milk cap powder to the blender container, stir manually with a spatula, press down the blender and turn it to medium speed for 2-8 minutes. The hardness can be increased with the extension of the mixing time.","km":"គ្រីម Evergreen (Evergreen Cream): ៥០០ ក្រាម\nទឹកដោះគោស្រស់: ១០០០ ក្រាម (១ លីត្រ)\nម្សៅមីលឃែប (Milk Cap Powder): ៥០០ ក្រាម\nដាក់គ្រឿងផ្សំទាំង ៣ មុខខាងលើចូលទៅក្នុងធុងម៉ាស៊ីនក្រឡុកក្នុងពេលតែមួយ។\nប្រើវែកកូរដោយដៃតិចៗឱ្យសព្វសាច់សិន។\nដាក់ធុងចូលម៉ាស៊ីន រួចបើកល្បឿនមធ្យម រយៈពេលពី ២ ទៅ ៨ នាទី។\nចំណាំ៖ បើអ្នកចង់ឱ្យវា \"កាន់តែរឹង ឬខាប់ខ្លាំង\" អ្នកអាចបង្កើនរយៈពេលនៃការក្រឡុកឱ្យយូរបន្តិចបាន។"},"type":"text"},"custom_field_1766720504769_b0kz9k9tf":{"name":{"en":"Storage condition:","km":"លក្ខខណ្ឌផ្ទុក៖"},"value":{"en":"stored in a cool and dry place, please use it in time or keep it in a sealed place after opening.","km":"សូមរក្សាទុកក្នុងកន្លែងត្រជាក់ ស្ងួត និងមិនត្រូវពន្លឺថ្ងៃ។ ក្រោយពេលបើកប្រើរួចរាល់ សូមបិទមាត់ថង់/ដបឱ្យជិតវិញ។"},"type":"text"},"custom_field_1766720665426_kuu3jcn6p":{"name":{"en":"Shelf life:","km":"អាយុកាល៖"},"value":{"en":"12 months","km":"​១២ខែ"},"type":"text"},"custom_field_1766720750027_ke5fklr8i":{"name":{"en":"Nutrition information:","km":"ព័ត៌មានអាហារូបត្ថម្ភ៖"},"value":[{"label":{"en":"Energy","km":"ថាមពល"},"value":[{"en":"2046KJ","km":"2046KJ"},{"en":"24%","km":"24%"}]},{"label":{"en":"Protein","km":"ប្រូតេអ៊ីន"},"value":[{"en":"3.6g","km":"3.6g"},{"en":"6%","km":"6%"}]},{"label":{"en":"Fat","km":"ខ្លាញ់"},"value":[{"en":"27.0g","km":"27.0g"},{"en":"45%","km":"45%"}]},{"label":{"en":"Trans fats (acid)","km":"ខ្លាញ់ trans (អាស៊ីត)"},"value":[{"en":"0g","km":"0g"},{"en":"0%","km":"0%"}]},{"label":{"en":"Carbohydrate","km":"កាបូអ៊ីដ្រាត"},"value":[{"en":"58.0g","km":"58.0g"},{"en":"19%","km":"19%"}]},{"label":{"en":"Sodium","km":"សូដ្យូម"},"value":[{"en":"1598mg","km":"1598mg"},{"en":"80%","km":"80%"}]}],"type":"table"},"custom_field_1766720720240_734qiixth":{"name":{"en":"Allergen information:","km":"ព័ត៌មានអំពីសារធាតុបង្កអាឡែហ្ស៊ី៖"},"value":{"en":"This production line simultaneously produces products containing dairy products, grains, peanuts, soybeans, and nuts","km":"ខ្សែសង្វាក់ផលិតកម្មនេះ ក៏ផលិតនូវផលិតផលផ្សេងទៀតដែលមានផ្ទុកនូវ គ្រឿងផ្សំពីទឹកដោះគោ, គ្រាប់ធញ្ញជាតិ, សណ្តែកដី, សណ្តែកសៀង និងគ្រាប់រុក្ខជាតិផ្សេងៗ ក្នុងពេលតែមួយផងដែរ។\nឃ្លានេះគឺជាការព្រមានសម្រាប់អ្នកដែលមាន ប្រតិកម្ម (អាឡែហ្ស៊ី) ជាមួយអាហារខាងលើ។ ទោះបីជាផលិតផលដែលអ្នកទិញមិនមែនជាប្រភេទសណ្តែក ឬទឹកដោះគោក៏ដោយ ប៉ុន្តែវាត្រូវបានផលិតចេញពីម៉ាស៊ីនជាមួយគ្នា ដែលអាចធ្វើឱ្យមានការ \"ឆ្លងម