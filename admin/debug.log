    [custom_fields_data_edit] => {"custom_field_1766726901313_aovq7aqvr":{"name":{"en":"Ingredients:","km":"គ្រឿងផ្សំសំខាន់ៗ៖"},"value":{"en":"Edible Dextrose, Non-Dairy Creamer (Glucose Syrup, Refined Vegetable Oil, Milk Powder, Mono- and Diglycerides, Sodium Stearoyl Lactylate, Dipotassium Phosphate, Silicon Dioxide, Annatto, Food Flavoring), Matcha Powder, Food Additives (Silicon Dioxide, Tartrazine, Brilliant Blue FCF), Flavoring","km":"Edible Dextrose (ស្ករដេតស្រូស): ជាប្រភេទស្ករម្សៅម្យ៉ាងដែលចម្រាញ់ចេញពីពោត ផ្ដល់រសជាតិផ្អែមស្រទន់។,Matcha Powder (ម្សៅម៉ាត់ឆា): ម្សៅតែបៃតងជប៉ុន។,Flavoring (គ្រឿងទេសជួយក្លិន): សារធាតុបន្ថែមដើម្បីឱ្យមានក្លិនឈ្ងុយ។,ម្សៅគ្រីមឺរ (Non-Dairy Creamer),Glucose Syrup: ទឹកសសរផ្អែម។,Refined Vegetable Oil: ប្រេងបន្លែដែលចម្រាញ់រួច។,Milk Powder: ម្សៅទឹកដោះគោ។,Mono- and Diglycerides & Sodium Stearoyl Lactylate: សារធាតុជួយឱ្យទឹក និងប្រេងចូលគ្នាបានល្អ (មិនបែកស្រទាប់)។,Dipotassium Phosphate: សារធាតុការពារកុំឱ្យម្សៅកកដុំៗ។,Silicon Dioxide: សារធាតុការពារសំណើម កុំឱ្យម្សៅស្អិតជាប់គ្នា។,Annatto: ល័ក្ខធម្មជាតិសម្រាប់ផ្ដល់ពណ៌។,សារធាតុបន្ថែមពណ៌ និងរក្សាគុណភាព (Food Additives),Tartrazine: ពណ៌លឿងអាហារ។,Brilliant Blue FCF: ពណ៌ខៀវអាហារ (កាលណាគេលាយពណ៌លឿង និងខៀវបញ្ចូលគ្នា វានឹងបង្កើតបានជាពណ៌បៃតងស្រស់)។"},"type":"text"},"custom_field_1766727038536_p76b9vkkg":{"name":{"en":"Directions:","km":"របៀបឆុង៖"},"value":{"en":"Start with an appropriate amount of matcha powder in a cup. Gradually add about 5 parts hot water, mix well, and it's ready to drink. The ratio can be adjusted to taste.\nCan be served hot or cold.","km":"ជាដំបូង ដួសម្សៅម៉ាត់ឆា (Matcha) ក្នុងបរិមាណសមល្មមដាក់ក្នុងពែង។\nបន្ទាប់មក ចាក់ទឹកក្តៅចូលបន្តិចម្តងៗ (ក្នុងសមាមាត្រទឹក ៥ ភាគ ធៀបនឹងម្សៅ)។\nកូរឱ្យសព្វល្អ ជាការស្រេច។\n\nចំណាំ៖ អ្នកអាចថែមថយបរិមាណទឹក ឬម្សៅទៅតាមចំណូលចិត្ត (ចង់បានរសជាតិចាស់ ឬស្ទើរ)។ ភេសជ្ជៈនេះអាចញ៉ាំបានទាំង ក្តៅ ឬ ត្រជាក់។"},"type":"text"},"custom_field_1766727039009_ox7exkf0e":{"name":{"en":"Storage conditions:","km":"លក្ខខណ្ឌផ្ទុក៖"},"value":{"en":"stored in cool, dry, light-proof\nplace, after opening, please use it in time or keep it sealed","km":"សូមរក្សាទុកក្នុងកន្លែងត្រជាក់ ស្ងួត និងមិនត្រូវពន្លឺថ្ងៃ។ ក្រោយពេលបើកប្រើរួចរាល់ សូមបិទមាត់ថង់/ដបឱ្យជិតវិញ។"},"type":"text"},"custom_field_1766727039441_5ckpir092":{"name":{"en":"Shelf life:","km":"អាយុកាល៖"},"value":{"en":"12 months","km":"១២ ខែ"},"type":"text"},"custom_field_1766727039816_vdm0n3lhf":{"name":{"en":"Allergen information:","km":"ព័ត៌មានអំពីសារធាតុបង្កអាឡែហ្ស៊ី៖"},"value":{"en":"This production line\nsimultaneously produces products containing dairy products, grains, peanuts, soybeans, and nuts","km":"ខ្សែសង្វាក់ផលិតកម្មនេះ ក៏ផលិតនូវផលិតផលផ្សេងទៀតដែលមានផ្ទុកនូវ គ្រឿងផ្សំពីទឹកដោះគោ, គ្រាប់ធញ្ញជាតិ, សណ្តែកដី, សណ្តែកសៀង និងគ្រាប់រុក្ខជាតិផ្សេងៗ ក្នុងពេលតែមួយផងដែរ។\nឃ្លានេះគឺជាការព្រមានសម្រាប់អ្នកដែលមាន ប្រតិកម្ម (អាឡែហ្ស៊ី) ជាមួយអាហារខាងលើ។ ទោះបីជាផលិតផលដែលអ្នកទិញមិនមែនជាប្រភេទសណ្តែក ឬទឹកដោះគោក៏ដោយ ប៉ុន្តែវាត្រូវបានផលិតចេញពីម៉ាស៊ីនជាមួយគ្នា ដែលអាចធ្វើឱ្យមានការ \"ឆ្លងមេរោគអាឡែហ្ស៊ី\" បន្តិចបន្តួចពីផលិតផលមួយទៅផលិតផលមួយទៀតបាន។"},"type":"text"},"custom_field_1766727040193_we824kqkk":{"name":{"en":"Nutrition information","km":"ព័ត៌មានអាហារូបត្ថម្ភ៖"},"value":[{"label":{"en":"energy","km":"ថាមពល"},"value":[{"en":"1591KJ","km":"1591KJ"},{"en":"19%","km":"19%"}]},{"label":{"en":"protein","km":"ប្រូតេអ៊ីន"},"value":[{"en":"0g","km":"0%"},{"en":"0g","km":"0%"}]},{"label":{"en":"fat","km":"ខ្លាញ់"},"value":[{"en":"6.7g","km":"6.7g"},{"en":"11%","km":"11%"}]},{"label":{"en":"carbohydrate","km":"កាបូអ៊ីដ្រាត"},"value":[{"en":"79.0g","km":"79.0g"},{"en":"26%","km":"26%"}]},{"label":{"en":"sodium","km":"សូដ្យូម"},"value":[{"en":"122mg","km":"122mg"},{"en":"6%","km":"6%"}]}],"type":"table"},"custom_field_1766727259531_3rpczoa76":{"name":{"en":"Origin:","km":"ប្រភព៖"},"value":{"en":"China","km":"ប្រទេសចិន"},"type":"text"}}
