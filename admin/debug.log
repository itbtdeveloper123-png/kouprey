 after opening, please use it in time or keep it sealed","km":"សូមរក្សាទុកក្នុងកន្លែងត្រជាក់ ស្ងួត និងមិនត្រូវពន្លឺថ្ងៃ។ ក្រោយពេលបើកប្រើរួចរាល់ សូមបិទមាត់ថង់/ដបឱ្យជិតវិញ។"},"type":"text"},"custom_field_1766727039441_5ckpir092":{"name":{"en":"Shelf life:","km":"អាយុកាល៖"},"value":{"en":"12 months","km":"១២ ខែ"},"type":"text"},"custom_field_1766727039816_vdm0n3lhf":{"name":{"en":"Allergen information:","km":"ព័ត៌មានអំពីសារធាតុបង្កអាឡែហ្ស៊ី៖"},"value":{"en":"This production line\nsimultaneously produces products containing dairy products, grains, peanuts, soybeans, and nuts","km":"ខ្សែសង្វាក់ផលិតកម្មនេះ ក៏ផលិតនូវផលិតផលផ្សេងទៀតដែលមានផ្ទុកនូវ គ្រឿងផ្សំពីទឹកដោះគោ, គ្រាប់ធញ្ញជាតិ, សណ្តែកដី, សណ្តែកសៀង និងគ្រាប់រុក្ខជាតិផ្សេងៗ ក្នុងពេលតែមួយផងដែរ។\nឃ្លានេះគឺជាការព្រមានសម្រាប់អ្នកដែលមាន ប្រតិកម្ម (អាឡែហ្ស៊ី) ជាមួយអាហារខាងលើ។ ទោះបីជាផលិតផលដែលអ្នកទិញមិនមែនជាប្រភេទសណ្តែក ឬទឹកដោះគោក៏ដោយ ប៉ុន្តែវាត្រូវបានផលិតចេញពីម៉ាស៊ីនជាមួយគ្នា ដែលអាចធ្វើឱ្យមានការ \"ឆ្លងមេរោគអាឡែហ្ស៊ី\" បន្តិចបន្តួចពីផលិតផលមួយទៅផលិតផលមួយទៀតបាន។"},"type":"text"},"custom_field_1766727040193_we824kqkk":{"name":{"en":"Nutrition information","km":"ព័ត៌មានអាហារូបត្ថម្ភ៖"},"value":[{"label":{"en":"energy","km":"ថាមពល"},"value":[{"en":"1591KJ","km":"1591KJ"},{"en":"19%","km":"19%"}]},{"label":{"en":"protein","km":"ប្រូតេអ៊ីន"},"value":[{"en":"0g","km":"0%"},{"en":"0g","km":"0%"}]},{"label":{"en":"fat","km":"ខ្លាញ់"},"value":[{"en":"6.7g","km":"6.7g"},{"en":"11%","km":"11%"}]},{"label":{"en":"carbohydrate","km":"កាបូអ៊ីដ្រាត"},"value":[{"en":"79.0g","km":"79.0g"},{"en":"26%","km":"26%"}]},{"label":{"en":"sodium","km":"សូដ្យូម"},"value":[{"en":"122mg","km":"122mg"},{"en":"6%","km":"6%"}]}],"type":"table"},"custom_field_1766727259531_3rpczoa76":{"name":{"en":"Origin:","km":"ប្រភព៖"},"value":{"en":"China","km":"ប្រទេសចិន"},"type":"text"}}
