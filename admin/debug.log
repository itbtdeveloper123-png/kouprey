    [custom_fields_data_edit] => {"custom_field_1766718792091_l22i6gum6":{"name":{"en":"Ingredients:","km":"គ្រឿងផ្សំសំខានៗ៖"},"value":{"en":"Non-Dairy Creamer (Glucose Syrup, Refined Palm Oil, Sodium Caseinate, Dipotassium Phosphate, Sodium Carboxymethyl Cellulose, Mono- and Diglycerides, Sodium Stearoyl Lactylate, Lecithin, Silicon Dioxide, Food Flavoring), Edible Glucose, White Sugar, Lactose, Food Additives (Brilliant Blue, Carmine, Silicon Dioxide), Flavoring","km":"ម្សៅគ្រីមមឺរ (Non-Dairy Creamer): ជាប្រភេទម្សៅទឹកដោះគោសិប្បនិម្មិត ដែលមានធាតុផ្សំដូចជា៖(Glucose Syrup: ទឹកសរ៉ូស្ករ (ធ្វើពីម្សៅជាតិម្សៅ),Refined Palm Oil: ប្រេងដូងចម្រាញ់,Sodium Caseinate: សារធាតុប្រូតេអ៊ីនទាញចេញពីទឹកដោះគោ (ជួយឱ្យមានជាតិខ្ទិះ),Dipotassium Phosphate: សារធាតុជួយរក្សាកម្រិតអាស៊ីត និងការពារកុំឱ្យម្សៅកកដុំៗ,Sodium Carboxymethyl Cellulose: សារធាតុធ្វើឱ្យខាប់,Mono- and Diglycerides: សារធាតុជួយឱ្យទឹក និងប្រេងចូលគ្នាបានល្អ,Sodium Stearoyl Lactylate: សារធាតុជំនួយដល់សាច់ផលិតផលឱ្យទន់រលោង,Lecithin: សារធាតុចម្រាញ់ពីសណ្តែកសៀង ឬស៊ុត (ជួយរំលាយ),Silicon Dioxide: សារធាតុការពារកុំឱ្យម្សៅស្អិតជាប់គ្នា,Food Flavoring: ក្លិនរសជាតិអាហារ,Edible Glucose: ស្ករគ្លុយកូស (ស្ករដែលអាចបរិភោគបាន),White Sugar: ស្ករស,Lactose: ស្ករទឹកដោះគោ,Food Additives (សារធាតុបន្ថែមក្នុងអាហារ):,Brilliant Blue: ល័ក្ខពណ៌ខៀវ,Carmine: ល័ក្ខពណ៌ក្រហម,Silicon Dioxide: សារធាតុការពារការកកដុំ),Flavoring: សារធាតុក្លិនក្រអូប"},"type":"text"},"custom_field_1766719109595_obzwvxzxe":{"name":{"en":"Storage conditions:","km":"លក្ខខណ្ឌផ្ទុក៖"},"value":{"en":"stored in cool, dry, light-proof place, after opening, please use it in time or keep it sealed.","km":"សូមរក្សាទុកក្នុងកន្លែងត្រជាក់ ស្ងួត និងមិនត្រូវពន្លឺថ្ងៃ។ ក្រោយពេលបើកប្រើរួចរាល់ សូមបិទមាត់ថង់/ដបឱ្យជិតវិញ។"},"type":"text"},"custom_field_1766719242539_916kf7ni9":{"name":{"en":"How to cook:","km":"របៀបឆុង៖"},"value":{"en":"Into a shaker, add in order: 30g of fructose, 20g of non-dairy creamer, 10g of this product (black tea base), and 180mL of brewed black tea. Then, add ice to the brim. Shake vigorously 20 times to serve.","km":"១. ដាក់គ្រឿងផ្សំចូលក្នុងកែវក្រឡុក (Shaker) តាមលំដាប់លំដោយ៖\n\nស្ករទឹក (Fructose): ៣០ ក្រាម\n\nម្សៅទឹកដោះគោ (Non-dairy creamer): ២០ ក្រាម\n\nម្សៅតែខ្មៅ (ផលិតផលនេះ): ១០ ក្រាម\n\nទឹកតែខ្មៅ (ដែលឆុងរួច): ១៨០ មីលីលីត្រ\n\n២. បន្ថែមទឹកកក៖ ដាក់ទឹកកកចូលឱ្យពេញមាត់កែវក្រឡុក។\n\n៣. ក្រឡុក៖ ក្រឡុកឱ្យខ្លាំងៗចំនួន ២០ ដង រួចចាក់ដាក់កែវជាការស្រេច។"},"type":"text"},"custom_field_1766719329106_3wvbwngka":{"name":{"en":"Shelf life:","km":"អាយុកាល៖"},"value":{"en":"12 months","km":"១២ ខែ"},"type":"text"},"custom_field_1766719365234_65vntcjar":{"name":{"en":"Nutrition information","km":"ព័ត៌មានអាហារូបត្ថម្ភ"},"value":[{"label":{"en":"energy","km":"ថាមពល"},"value":[{"en":"1610KJ","km":"1610KJ"},{"en":"19%","km":"19%"}]},{"label":{"en":"protein","km":"ប្រូតេអ៊ីន"},"value":[{"en":"0g","km":"0g"},{"en":"0%","km":"0%"}]},{"label":{"en":"fat","km":"ខ្លាញ់"},"value":[{"en":"4.7g","km":"4.7g"},{"en":"8%","km":"8%"}]},{"label":{"en":"carbohydrate","km":"កាបូអ៊ីដ្រាត"},"value":[{"en":"84.5g","km":"84.5g"},{"en":"28%","km":"28%"}]},{"label":{"en":"sodium","km":"សូដ្យូម"},"value":[{"en":"30mg","km":"30mg"},{"en":"2%","km":"2%"}]}],"type":"table"},"custom_field_1766719611122_621nqtxvr":{"name":{"en":"Allergen information:","km":"ព័ត៌មានអំពីសារធាតុបង្កអាឡែហ្ស៊ី៖"},"value":{"en":"This production line simultaneously produces products containing dairy products, grains, peanuts, soybeans, and nuts","km":"ខ្សែសង្វាក់ផលិតកម្មនេះ ក៏ផលិតនូវផលិតផលផ្សេងទៀតដែលមានផ្ទុកនូវ គ្រឿងផ្សំពីទឹកដោះគោ, គ្រាប់ធញ្ញជាតិ, សណ្តែកដី, សណ្តែកសៀង និងគ្រាប់រុក្ខជាតិផ្សេងៗ ក្នុងពេលតែមួយផងដែរ។\nឃ្លានេះគឺជាការព្រមានសម្រាប់អ្នកដែលមាន ប្រតិកម្ម (អាឡែហ្ស៊ី) ជាមួយអាហារខាងលើ។ ទោះបីជាផលិតផលដែលអ្នកទិញមិនមែនជាប្រភេទសណ្តែក ឬទឹកដោះគោក៏ដោយ ប៉ុន្តែវាត្រូវបានផលិតចេញពីម៉ាស៊ីនជាមួយគ្នា ដែលអាចធ្វើឱ្យមានការ \"ឆ្លងមេរោគអាឡែហ្ស៊ី\" បន្តិចបន្តួចពីផលិតផលមួយទៅផលិតផលមួយទៀតបាន។"},"type":"text"},"custom_field_1766719634213_fe0xpyqqp":{"name":{"en":"Origin:","km":"ប្រភព៖"},"value":{"en":"China","km":"ប្រទេសចិន"},"type":"text