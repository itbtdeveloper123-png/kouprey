    [custom_fields_data_edit] => {"custom_field_1766721651080_u7jjss457":{"name":{"en":"Ingredients:","km":"គ្រឿងផ្សំសំខាន់ៗ៖"},"value":{"en":"Coconut, water, fruit glucose syrup,\nkonjac flour, food additives (sodium carboxymethyl-cellulose, xanthan gum, citric acid, sodium citrate, potassium sorbate, sodium benzoate, sucralose), food flavours","km":"ដូង (Coconut),ទឹក (Water),ទឹកស៊ីរ៉ូផ្លែឈើ/ស្ករផ្លែឈើ (Fruit glucose syrup),ម្សៅមើមបុក (Konjac flour): ជាជាតិម្សៅដែលគេយកមកធ្វើជាចាហួយ,សារធាតុបន្ថែមក្នុងអាហារ (Food additives): សារធាតុធ្វើឱ្យខាប់ និងស្អិត (Sodium carboxymethyl-cellulose, Xanthan gum),សារធាតុរក្សាតុល្យភាពជាតិអាស៊ីត (Citric acid, Sodium citrate): ជួយឱ្យមានរសជាតិជូរអែម និងរក្សាគុណភាព។,សារធាតុរក្សាកុំឱ្យផ្អូម/ខូច (Potassium sorbate, Sodium benzoate): សារធាតុការពារកុំឱ្យដុះផ្សិត ឬខូច។,ស្ករសិប្បនិម្មិត (Sucralose): ជាសារធាតុផ្តល់ភាពផ្អែមជំនួសស្ករធម្មតា (ផ្អែមខ្លាំងតែអត់កាឡូរី)។,ក្លិនក្រអូបសិប្បនិម្មិត (Food flavours): ភ្នាក់ងារដែលជួយឱ្យមានក្លិនឈ្ងុយតាមបែបអាហារ។"},"type":"text"},"custom_field_1766721765143_adujhygrv":{"name":{"en":"Edible method:","km":"វិធីសាស្រ្តដែលអាចបរិភោគបាន៖"},"value":{"en":"Add this\nproduct to drinks for seasoning, the amount of addition is 5%-15%","km":"សូមបន្ថែមផលិតផលនេះទៅក្នុងភេសជ្ជៈដើម្បីបង្កើនរសជាតិ ក្នុងបរិមាណពី ៥% ទៅ ១៥%។"},"type":"text"},"custom_field_1766721834063_vrgp4rwpk":{"name":{"en":"Storage Conditions:","km":"លក្ខខណ្ឌផ្ទុក៖"},"value":{"en":"Store in a cool place,\naway from light. Please consume as soon as possible after opening.","km":"សូមរក្សាទុកក្នុងកន្លែងត្រជាក់ ស្ងួត និងមិនត្រូវពន្លឺថ្ងៃ។ ក្រោយពេលបើកប្រើរួចរាល់ សូមបិទមាត់ថង់/ដបឱ្យជិតវិញ។"},"type":"text"},"custom_field_1766721930335_382i0eh5x":{"name":{"en":"Shelf life:","km":"អាយុកាល៖"},"value":{"en":"12 months","km":"១២ ខែ"},"type":"text"},"custom_field_1766721969887_okraqvlnc":{"name":{"en":"Nutrition information","km":"ព័ត៌មានអាហារូបត្ថម្ភ"},"value":[{"label":{"en":"energy","km":"ថាមពល"},"value":[{"en":"179kJ","km":"179kJ"},{"en":"2%","km":"2%"}]},{"label":{"en":